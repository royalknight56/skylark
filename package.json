{
	"name": "skylark",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "next lint",
		"deploy": "opennextjs-cloudflare build && wrangler deploy",
		"upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
		"preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"super-admin:hash": "node scripts/super-admin-hash.mjs",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"db:init": "wrangler d1 execute skylarkd1 --local --file src/lib/db/schema.sql",
		"db:migrate:mail": "wrangler d1 execute skylarkd1 --local --file migrations/0001_auth_mail_system.sql",
		"db:migrate:perf": "wrangler d1 execute skylarkd1 --local --file migrations/0002_performance_indexes.sql",
		"db:migrate:feedback": "wrangler d1 execute skylarkd1 --local --file migrations/0003_product_feedback.sql",
		"db:init:remote": "wrangler d1 execute skylarkd1 --remote --file src/lib/db/schema.sql",
		"db:migrate:mail:remote": "wrangler d1 execute skylarkd1 --remote --file migrations/0001_auth_mail_system.sql",
		"db:migrate:perf:remote": "wrangler d1 execute skylarkd1 --remote --file migrations/0002_performance_indexes.sql",
		"db:migrate:feedback:remote": "wrangler d1 execute skylarkd1 --remote --file migrations/0003_product_feedback.sql"
	},
	"dependencies": {
		"@opennextjs/cloudflare": "^1.19.1",
		"@tiptap/extension-highlight": "^3.22.4",
		"@tiptap/extension-image": "^3.22.4",
		"@tiptap/extension-link": "^3.22.4",
		"@tiptap/extension-list": "^3.22.4",
		"@tiptap/extension-placeholder": "^3.22.4",
		"@tiptap/extension-table": "^3.22.4",
		"@tiptap/extension-text-align": "^3.22.4",
		"@tiptap/extension-text-style": "^3.22.4",
		"@tiptap/extension-underline": "^3.22.4",
		"@tiptap/pm": "^3.22.4",
		"@tiptap/react": "^3.22.4",
		"@tiptap/starter-kit": "^3.22.4",
		"lucide-react": "^1.8.0",
		"next": "16.2.3",
		"react": "19.1.5",
		"react-dom": "19.1.5"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20.19.39",
		"@types/react": "^19.1.5",
		"@types/react-dom": "^19.1.5",
		"eslint": "^9",
		"eslint-config-next": "15.4.6",
		"tailwindcss": "^4",
		"typescript": "^5.7.4",
		"wrangler": "^4.84.1"
	}
}
