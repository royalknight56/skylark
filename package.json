{
	"name": "skylark",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "next lint",
		"postbuild:cf": "node scripts/postbuild.mjs",
		"deploy": "opennextjs-cloudflare build && node scripts/postbuild.mjs && wrangler deploy",
		"upload": "opennextjs-cloudflare build && node scripts/postbuild.mjs && opennextjs-cloudflare upload",
		"preview": "opennextjs-cloudflare build && node scripts/postbuild.mjs && opennextjs-cloudflare preview",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
	},
	"dependencies": {
		"@opennextjs/cloudflare": "^1.19.1",
		"lucide-react": "^1.8.0",
		"next": "16.2.3",
		"react": "19.1.5",
		"react-dom": "19.1.5"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20.19.39",
		"@types/react": "^19.1.5",
		"@types/react-dom": "^19.1.5",
		"eslint": "^9",
		"eslint-config-next": "15.4.6",
		"tailwindcss": "^4",
		"typescript": "^5.7.4",
		"wrangler": "^4.84.1"
	}
}